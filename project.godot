; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="X. WHEEL"
config/description="A psychological horror visual novel about blind faith in the internet."
config/version="0.1.0"
config/tags=PackedStringArray("visual_novel", "horror", "pixel_art", "psychological")
run/main_scene="uid://menu0001"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GlobalState="*res://scripts/autoload/global_state.gd"
LanguageManager="*res://scripts/autoload/language_manager.gd"
DialogueManager="*res://scripts/autoload/dialogue_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
PollutionSystem="*res://scripts/autoload/pollution_system.gd"
SaveSystem="*res://scripts/autoload/save_system.gd"
GlitchEffect="*res://scripts/effects/glitch_effect.gd"
SceneTransitioner="*res://scripts/autoload/scene_transitioner.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="res://assets/fonts/fusion-pixel-12px-proportional-zh_hans.otf"

