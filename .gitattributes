* text=auto

# Repository metadata
.gitattributes text eol=lf
.gitignore text eol=lf

# Godot text resources should stay LF-only for stable diffs across platforms.
*.gd text eol=lf
*.gdshader text eol=lf
*.godot text eol=lf
*.import text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.uid text eol=lf
*.csv text eol=lf
*.translation text eol=lf
*.svg text eol=lf

# Binary assets
*.otf binary
*.ttf binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.wav binary
*.ogg binary
*.mp3 binary
